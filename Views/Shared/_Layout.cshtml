<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Colegio San José</title>

    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons (CDN para rapidez) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Estilos personalizados -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Sistema_Académico_Colegio_San_José.styles.css" asp-append-version="true" />
    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end" id="navbarMain">
        <ul class="navbar-nav align-items-center">
            <li class="nav-item border-start ms-lg-3 ps-lg-3">
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item ms-lg-3">
                            <a class="btn btn-danger btn-sm shadow-sm px-3 fw-bold"
                               style="border-radius: 8px;"
                               asp-controller="Account" asp-action="Logout">
                                <i class="bi bi-box-arrow-right me-1"></i> Cerrar Sesión
                            </a>
                        </li>
                    </ul>
                </div>
            </li>
        </ul>
    </div>
    <style>
        body {
            background-color: #f8f9fa;
        }

        .navbar-brand {
            font-size: 1.4rem;
            letter-spacing: -0.5px;
        }

        .nav-link {
            transition: all 0.3s ease;
        }

            .nav-link:hover {
                color: #ffc107 !important; /* Color dorado al pasar el mouse */
            }

        .footer {
            background-color: #ffff;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-mortarboard-fill me-2"></i> Colegio San José
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end" id="navbarMain">
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door"></i> Inicio
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Alumnoes" asp-action="Index">
                                <i class="bi bi-people"></i> Alumnos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Materias" asp-action="Index">
                                <i class="bi bi-book"></i> Materias
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Expedientes" asp-action="Index">
                                <i class="bi bi-folder2-open"></i> Expedientes
                            </a>
                        </li>
                        <!-- Botón destacado para la funcionalidad de Promedios -->
                        <li class="nav-item ms-lg-3">
                            <a class="btn btn-warning fw-bold shadow-sm px-3"
                               asp-controller="Expedientes" asp-action="Promedios">
                                <i class="bi bi-graph-up-arrow"></i> Promedios
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5 mt-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3 mt-auto">
        <div class="container text-center">
            &copy; 2026 - <span class="fw-bold text-primary">Colegio San José</span> -
            <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacidad</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>