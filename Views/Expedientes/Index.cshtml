@model IEnumerable<ColegioSanJose.Models.Expediente>

@{
    ViewData["Title"] = "Control de Expedientes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary fw-bold mb-0">
                <i class="bi bi-file-earmark-ruled me-2"></i>Control de Expedientes
            </h2>
            <p class="text-muted small">Registro centralizado de calificaciones</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm px-4">
            <i class="bi bi-file-earmark-plus-fill me-1"></i> Nuevo Registro
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-secondary">
                            <th class="ps-4 py-3">Estudiante</th>
                            <th class="py-3">Materia</th>
                            <th class="py-3 text-center">Nota Final</th>
                            <th class="py-3 text-center">Estado</th>
                            <th class="text-center py-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex justify-content-center align-items-center me-3" style="width: 35px; height: 35px;">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <div>
                                            <span class="fw-semibold d-block">@item.Alumno.Nombre @item.Alumno.Apellido</span>
                                            <small class="text-muted">ID: ALU-@item.AlumnoId.ToString("D3")</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-secondary">
                                        <i class="bi bi-bookmark-check me-2"></i>@item.Materia.NombreMateria
                                    </span>
                                </td>
                                <td class="text-center">
                                    @{
                                        // Definimos el color según la nota (6.0 es el estándar de aprobación)
                                        string colorClase = item.NotaFinal >= 6 ? "text-success" : "text-danger";
                                    }
                                    <span class="fw-bold fs-5 @colorClase">
                                        @((item.NotaFinal.HasValue) ? item.NotaFinal.Value.ToString("0.0") : "0.0")
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (item.NotaFinal >= 6)
                                    {
                                        <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3">
                                            Aprobado
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3">
                                            Reprobado
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.ExpedienteId" class="btn btn-sm btn-outline-primary border-0">
                                            <i class="bi bi-pencil-square fs-5"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.ExpedienteId" class="btn btn-sm btn-outline-info border-0">
                                            <i class="bi bi-eye-fill fs-5"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.ExpedienteId" class="btn btn-sm btn-outline-danger border-0">
                                            <i class="bi bi-trash3-fill fs-5"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>