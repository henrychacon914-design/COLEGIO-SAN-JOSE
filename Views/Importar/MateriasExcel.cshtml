<div class="container mt-5">
    <div class="card shadow-sm border-0 rounded-4 p-4" style="max-width: 600px; margin: auto;">
        <div class="text-center mb-4">
            <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex p-4 mb-3">
                <i class="bi bi-journal-plus text-success display-4"></i>
            </div>
            <h2 class="fw-bold">Carga Masiva de Materias</h2>
            <p class="text-muted">Suba el archivo Excel con el listado de asignaturas y docentes.</p>
        </div>

        <form asp-action="MateriasExcel" method="post" enctype="multipart/form-data">
            <div class="mb-4">
                <label class="form-label small fw-bold">Archivo Excel (.xlsx)</label>
                <input type="file" name="archivoExcel" class="form-control" accept=".xlsx" required />
                <div class="form-text mt-2">
                    <i class="bi bi-info-circle me-1"></i> Formato requerido: Columna A (Materia), Columna B (Docente).
                </div>
            </div>
            <button type="submit" class="btn btn-success w-100 py-2 fw-bold">
                <i class="bi bi-cloud-arrow-up-fill me-2"></i> Importar Materias
            </button>
            <a asp-controller="Materias" asp-action="Index" class="btn btn-link w-100 mt-2 text-muted">Cancelar</a>
        </form>
    </div>
</div>