<div class="container mt-5">
    <div class="form-text mt-2">
        <i class="bi bi-info-circle me-1"></i>
        <strong>Formato:</strong> Col A (Nombre), Col B (Apellido), Col C (Fecha: dd/mm/aaaa), Col D (Grado).
    </div>
    <div class="card shadow-sm border-0 rounded-4 p-4">
        <div class="text-center mb-4">
            <i class="bi bi-file-earmark-excel-fill text-success display-1"></i>
            <h2 class="fw-bold mt-2">Importar Alumnos desde Excel</h2>
            <p class="text-muted">El sistema creará automáticamente los expedientes para todas las materias.</p>
        </div>

        <form asp-action="AlumnosExcel" method="post" enctype="multipart/form-data">
            <div class="mb-4">
                <label class="form-label fw-bold">Seleccione archivo (.xlsx)</label>
                <input type="file" name="archivoExcel" class="form-control form-control-lg" accept=".xlsx" required />
            </div>
            <button type="submit" class="btn btn-success w-100 py-3 fw-bold">
                <i class="bi bi-cloud-upload me-2"></i> Procesar e Inscribir Alumnos
            </button>
        </form>
    </div>
</div>